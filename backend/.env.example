# --- Application ---
APP_NAME=LeafMind
APP_VERSION=0.1.0
ENVIRONMENT=development
DEBUG=true

# --- CORS (comma-separated origins) ---
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# --- Database ---
DATABASE_URL=postgresql+asyncpg://leafmind:leafmind@localhost:5432/leafmind
DATABASE_ECHO=false
DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=10

# --- Logging ---
LOG_LEVEL=INFO
LOG_DIR=logs
LOG_ROTATION=10 MB
LOG_RETENTION=14 days
LOG_SERIALIZE_JSON=false

# --- Security / JWT (Sprint 2: Authentication) ---
JWT_SECRET_KEY=changeme-not-for-production
JWT_REFRESH_SECRET_KEY=changeme-refresh-not-for-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30
JWT_ISSUER=leafmind-api

# --- Password policy ---
PASSWORD_MIN_LENGTH=8
PASSWORD_REQUIRE_UPPERCASE=true
PASSWORD_REQUIRE_LOWERCASE=true
PASSWORD_REQUIRE_DIGIT=true
PASSWORD_REQUIRE_SPECIAL=true

# --- RBAC ---
DEFAULT_USER_ROLE=user

# --- Dataset (Sprint 3: Image Analysis) ---
DATASET_ROOT=../datasets
DATASET_RAW_SUBDIR=raw/medicinal_leaf_images
DATASET_METADATA_SUBDIR=metadata

# --- Upload storage ---
UPLOAD_DIR=uploads
MAX_UPLOAD_SIZE_MB=15
ALLOWED_UPLOAD_CONTENT_TYPES=image/jpeg,image/png,image/webp

# --- Image preprocessing pipeline ---
PREPROCESS_TARGET_SIZE=448
PREPROCESS_DENOISE_STRENGTH=5
PREPROCESS_CONTRAST_CLIP_LIMIT=2.0
PREPROCESS_SAVE_INTERMEDIATE=false

# --- Vision-Language Model (Qwen2.5-VL) ---
VLM_MODEL_NAME=Qwen/Qwen2.5-VL-3B-Instruct
VLM_DEVICE=auto
VLM_DTYPE=auto
VLM_MAX_NEW_TOKENS=512
VLM_TEMPERATURE=0.2
VLM_TOP_P=0.9
VLM_MIN_PIXELS=200704
VLM_MAX_PIXELS=1003520
VLM_TOP_K_CANDIDATES=3
VLM_LOAD_ON_STARTUP=false

# --- Chat (VLM-only, pre-RAG) ---
CHAT_MAX_HISTORY_MESSAGES=10
CHAT_MAX_NEW_TOKENS=400

# --- ChromaDB / RAG (future sprint placeholders) ---
CHROMADB_HOST=localhost
CHROMADB_PORT=8001
